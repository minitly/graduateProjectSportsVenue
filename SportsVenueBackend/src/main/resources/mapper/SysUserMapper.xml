<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tly.mapper.SysUserMapper">

    <resultMap id="SysUserResultMap" type="com.tly.entity.SysUser">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="realName" column="real_name"/>
        <result property="role" column="role"/>
        <result property="status" column="status"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="findByUsername" parameterType="string" resultMap="SysUserResultMap">
        select
            id,
            username,
            password,
            real_name,
            role,
            status,
            phone,
            email,
            create_time,
            update_time
        from sys_user
        where username = #{username}
        limit 1
    </select>

    <insert id="insert" parameterType="com.tly.entity.SysUser" useGeneratedKeys="true" keyProperty="id">
        insert into sys_user
        (username, password, real_name, role, status, phone, email, create_time, update_time)
        values
        (#{username}, #{password}, #{realName}, #{role}, #{status}, #{phone}, #{email}, now(), now())
    </insert>

    <select id="findPermissionCodesByRole" parameterType="string" resultType="string">
        select
            permission_code
        from sys_role_permission
        where role = #{role}
    </select>

</mapper>

