        {
          "name": "06-文件上传-单张或多张",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [], "description": "可选多个文件（添加多个 file 键）" },
                { "key": "biz", "value": "venue", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/files/upload"
          },
          "response": []
        },
        {
          "name": "07-图片获取-单张或多张",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/files/serve?path=/upload/venue/替换为上传返回的path"
          },
          "response": []
        }
      ]
