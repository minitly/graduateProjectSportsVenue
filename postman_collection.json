        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"user01\",\n  \"password\": \"123456\",\n  \"realName\": \"普通用户01\",\n  \"role\": \"USER\",\n  \"adminPassword\": \"\",\n  \"phone\": \"13800000001\",\n  \"email\": \"user01@example.com\"\n}"
        },
        "url": {
          "raw": "http://localhost:9999/sportsVenue/auth/register",
          "protocol": "http",
          "host": ["localhost"],
          "port": "9999",
          "path": ["sportsVenue", "auth", "register"]
        }
      },
      "response": []
